---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'GeldPsychologie: beter gedrag, betere keuzes, meer rust.' } = Astro.props;
const path = Astro.url.pathname;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/tools', label: 'Tools' },
  { href: '/kennis', label: 'Kennis' },
  { href: '/methodiek', label: 'Methodiek' },
  { href: '/coaching', label: 'Coaching' },
  { href: '/over', label: 'Over' }
];

const base = import.meta.env.BASE_URL;
const withBase = (href: string) => `${base}${href.replace(/^\//, '')}`;
const homeHref = base;
const normalize = (value: string) => (value.endsWith('/') && value !== '/' ? value.slice(0, -1) : value);
const isActive = (href: string) => {
  const current = normalize(path);

  if (href === '/') {
    return current === normalize(base) || current === '/';
  }

  return current.startsWith(normalize(withBase(href)));
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={withBase('/assets/img/geldpsychologie-logo.svg')} />
    <link rel="icon" href={withBase('/assets/img/geldpsychologie-logo.svg')} />
  </head>
  <body>
    <div class="bg-orb bg-orb-one"></div>
    <div class="bg-orb bg-orb-two"></div>

    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href={homeHref}>
          <img src={withBase('/assets/img/geldpsychologie-logo.svg')} alt="GeldPsychologie logo" />
          <span>GeldPsychologie</span>
        </a>
        <nav>
          {nav.map((item) => (
            <a class={isActive(item.href) ? 'active' : ''} href={item.href === '/' ? homeHref : withBase(item.href)}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div>
          <a href={withBase('/tools')}>Tools</a>
          <a href={withBase('/kennis')}>Kennis</a>
          <a href={withBase('/methodiek')}>Methodiek</a>
          <a href={withBase('/coaching')}>Coaching</a>
          <a href={withBase('/over')}>Over</a>
        </div>
        <div>
          <a href={withBase('/disclaimer')}>Disclaimer</a>
          <a href={withBase('/privacy')}>Privacy</a>
          <a href={withBase('/contact')}>Contact</a>
        </div>
      </div>
    </footer>
  </body>
</html>
