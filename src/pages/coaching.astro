---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Coaching | GeldPsychologie" description="Begeleiding voor financiële rust, richting en emotioneel stabiel beleggen.">
  <section class="hero">
    <h1>Coaching</h1>
    <p>Voor mensen die financiële rust willen, beter willen beleggen en hun plan willen begrijpen.</p>
  </section>
  <section class="grid grid-2">
    <article class="card"><h2>Voor wie?</h2><ul><li>financiële rust willen</li><li>beter willen beleggen</li><li>hun plan willen begrijpen</li><li>emotioneel stabiel willen investeren</li></ul></article>
    <article class="card"><h2>Wat we doen</h2><ol><li>financiële helderheid</li><li>plan en strategie</li><li>risicobewustzijn</li><li>duurzaam inkomen</li></ol></article>
    <article class="card"><h2>Format</h2><ul><li>intake</li><li>2–3 sessies</li><li>opvolging</li></ul></article>
    <article class="card"><h2>Resultaat</h2><ul><li>meer richting</li><li>minder financiële stress</li><li>realistische verwachtingen</li><li>duidelijke strategie</li></ul></article>
  </section>
</BaseLayout>
